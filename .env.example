# Copy to .env and fill in. Never commit the real .env.

# Password hash for the web UI login.
# Generate with:  python scripts/hash-password.py
UI_PASSWORD_HASH=

# Secret used to sign session cookies. Generate a random one:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me

# Port the web UI listens on.
PORT=8080
HOST=0.0.0.0

# Set true only when serving over HTTPS (marks the session cookie Secure).
COOKIE_SECURE=false

# How often (seconds) metrics/status are polled and streamed.
METRICS_INTERVAL=2

# Extra pip index used when provisioning service venvs. piwheels provides
# prebuilt ARM wheels for the Pi; harmless on other platforms.
PIP_EXTRA_INDEX_URL=https://www.piwheels.org/simple
